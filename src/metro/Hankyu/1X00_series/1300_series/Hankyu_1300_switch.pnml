/*--------------------------------------------------------------------
스위치
--------------------------------------------------------------------*/
switch (FEAT_TRAINS, SELF, sw_Hankyu_1300_8car, position_in_vehid_chain % 8) {
    1:set_Hankyu_1300_panto_wagon;
    2:set_Hankyu_1300_wagon;
    3:set_Hankyu_1300_wagon;
    4:set_Hankyu_1300_wagon;
    5:set_Hankyu_1300_panto_wagon;
    6:set_Hankyu_1300_wagon;
    7:set_Hankyu_1300_engineT;
    set_Hankyu_1300_engineH; //default
    }

switch (FEAT_TRAINS, SELF, sw_Hankyu_1300_8car_r, position_in_vehid_chain % 8) {
    1:set_Hankyu_1300_wagon_r;
    2:set_Hankyu_1300_panto_wagon_r;
    3:set_Hankyu_1300_wagon_r;
    4:set_Hankyu_1300_wagon_r;
    5:set_Hankyu_1300_wagon_r;
    6:set_Hankyu_1300_panto_wagon_r;
    7:set_Hankyu_1300_engineH_r;
    set_Hankyu_1300_engineT_r; //default
    }

switch(FEAT_TRAINS, SELF, sw_Hankyu_1300_8car_flipped, vehicle_is_flipped){
    0: sw_Hankyu_1300_8car_r;
    sw_Hankyu_1300_8car;
}

switch(FEAT_TRAINS, PARENT, sw_Hankyu_1300_8car_reversed, vehicle_is_reversed){
    0: sw_Hankyu_1300_8car;
    sw_Hankyu_1300_8car_flipped;
}

switch (FEAT_TRAINS, SELF, sw_articulated_Hankyu_1300_8car, extra_callback_info1) {
    1..7: Hankyu_1300_8Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }