// 편성그래픽
// 2량
switch (FEAT_TRAINS, SELF, sw_Hankyu_6000_2car, position_in_vehid_chain % 2) {
    1:sw_Hankyu_6000_2car_engineT;
    sw_Hankyu_6000_2car_engineH; //default
    }

// 3량
switch (FEAT_TRAINS, SELF, sw_Hankyu_6000_3car, position_in_vehid_chain % 3) {
    1:sw_Hankyu_6000_3car_wagon;
    2:sw_Hankyu_6000_3car_engineT;
    sw_Hankyu_6000_3car_engineH; //default
    }

// 4량
switch (FEAT_TRAINS, SELF, sw_Hankyu_6000_4car, position_in_vehid_chain % 4) {
    1..2:sw_Hankyu_6000_4car_wagon;
    3:sw_Hankyu_6000_4car_engineT;
    sw_Hankyu_6000_4car_engineH; //default
    }

// 6량
switch (FEAT_TRAINS, SELF, sw_Hankyu_6000_6car, position_in_vehid_chain % 6) {
    1..2:sw_Hankyu_6000_6car_wagon;
    3:sw_Hankyu_6000_6car_wagon_4Car;
    4:sw_Hankyu_6000_6car_wagon_5Car;
    5:sw_Hankyu_6000_6car_engineT;
    sw_Hankyu_6000_6car_engineH; //default
    }

