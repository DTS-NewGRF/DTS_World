    1:sw_Hankyu_6000_8car_wagon;
    2:sw_Hankyu_6000_8car_panto_wagon;
    3..4:sw_Hankyu_6000_8car_wagon;
    5:sw_Hankyu_6000_8car_panto_wagon;
    6:sw_Hankyu_6000_8car_wagon;
    7:sw_Hankyu_6000_8car_engineT;
    sw_Hankyu_6000_8car_engineH; //default
    }

// 편성량
switch (FEAT_TRAINS, SELF, sw_articulated_Hankyu_6000_2car, extra_callback_info1) {
    1: Hankyu_6000_2Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

