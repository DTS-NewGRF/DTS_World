// 도색
// 2, 4, 6량
switch(FEAT_TRAINS, SELF, sw_Hankyu_7000_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_Hankyu_7000);
    1: return string(STR_REFIT_LIVERY_Hankyu_7000_1998);
    2: return string(STR_REFIT_LIVERY_Hankyu_7000_2011);
