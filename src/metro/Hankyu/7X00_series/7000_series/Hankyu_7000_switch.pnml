}

switch(FEAT_TRAINS, SELF, sw_Hankyu_7000_8car_engineT_Front, cargo_subtype) {
    0..1: set_Hankyu_7000_engineT;
    2: set_Hankyu_7000_1998_engineT;
    3: set_Hankyu_7000_2009_engineT;
    4..5: set_Hankyu_7000_2011_engineT; 
}

// 후진방향
// 2, 4, 6량
switch(FEAT_TRAINS, SELF, sw_Hankyu_7000_engineH_Back, cargo_subtype) {
    0: set_Hankyu_7000_engineH_Rev;
    1: set_Hankyu_7000_1998_engineH_Rev;
