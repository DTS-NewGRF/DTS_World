// 사운드
switch(FEAT_TRAINS, SELF, sw_Hankyu_7000_8Car_2016_sound, cargo_subtype) {
    1: sw_Filed_Chopper_Control_sound;
    2: sw_Filed_Chopper_Control_sound;
    3: sw_Filed_Chopper_Control_sound;
    4: sw_Filed_Chopper_Control_sound;
    5: sw_TOSHIBAIGBTPMSMstart_sound;
    sw_Filed_Chopper_Control_sound;
}

switch(FEAT_TRAINS, SELF, sw_Hankyu_7000_8Car_sound, current_year) {
    0..2015: sw_Filed_Chopper_Control_sound;
    sw_Hankyu_7000_8Car_2016_sound;
    }

// 차량별 출력
