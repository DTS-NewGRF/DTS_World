    0..1: set_Hankyu_7000_wagon;
    2: set_Hankyu_7000_1998_wagon;
    3: set_Hankyu_7000_2009_wagon;
    4..5: set_Hankyu_7000_2011_wagon;
}

switch(FEAT_TRAINS, SELF, sw_Hankyu_7000_8car_wagon_6Car, cargo_subtype) {
    0: set_Hankyu_7000_panto_wagon;
    1: set_Hankyu_7000_wagon;
    2: set_Hankyu_7000_1998_wagon;
    3: set_Hankyu_7000_2009_wagon;
    4..5: set_Hankyu_7000_2011_wagon;
}

