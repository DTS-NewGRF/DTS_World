    2: set_Hankyu_7300_2008_panto_wagon;
    3..4: set_Hankyu_7300_2014_panto_wagon;
}

switch(FEAT_TRAINS, SELF, sw_Hankyu_7300_8car_engineT_Front, cargo_subtype) {
    0: set_Hankyu_7300_engineT;
    1: set_Hankyu_7300_1998_engineT;
    2: set_Hankyu_7300_2008_engineT;
    3..4: set_Hankyu_7300_2014_engineT;
}

