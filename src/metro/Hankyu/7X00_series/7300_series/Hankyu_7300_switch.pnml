    0: set_Hankyu_7300_engineH;
    1: set_Hankyu_7300_1998_engineH;
    2: set_Hankyu_7300_2008_engineH;
    3..4: set_Hankyu_7300_2014_engineH; 
}

switch(FEAT_TRAINS, SELF, sw_Hankyu_7300_8car_wagon, cargo_subtype) {
    0: set_Hankyu_7300_wagon;
