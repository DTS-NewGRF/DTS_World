switch(FEAT_TRAINS, SELF, sw_Hankyu_7300_engineH_Back, cargo_subtype) {
    0: set_Hankyu_7300_engineH_Rev;
    1: set_Hankyu_7300_1998_engineH_Rev;
    2: set_Hankyu_7300_2014_engineH;    
