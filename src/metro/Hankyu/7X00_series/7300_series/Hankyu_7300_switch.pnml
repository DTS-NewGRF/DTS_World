    0: set_Hankyu_7300_engineH_Rev;
    1: set_Hankyu_7300_1998_engineH_Rev;
    2: set_Hankyu_7300_2008_engineH_Rev;
    3..4: set_Hankyu_7300_2014_engineH_Rev;
}

