// 전후진 통합 코드
// 2, 6, 7량
switch(FEAT_TRAINS, SELF, sw_Hankyu_7300_engineH, train_is_driving_backwards) {
    0: sw_Hankyu_7300_engineH_Front;
    1: sw_Hankyu_7300_engineH_Back;
}

switch(FEAT_TRAINS, SELF, sw_Hankyu_7300_engineT, train_is_driving_backwards) {
    0: sw_Hankyu_7300_engineT_Front;
    1: sw_Hankyu_7300_engineT_Back;
}

// 8량
switch(FEAT_TRAINS, SELF, sw_Hankyu_7300_8car_engineH, train_is_driving_backwards) {
    0: sw_Hankyu_7300_8car_engineH_Front;
    1: sw_Hankyu_7300_8car_engineH_Back;
}

switch(FEAT_TRAINS, SELF, sw_Hankyu_7300_8car_engineT, train_is_driving_backwards) {
    0: sw_Hankyu_7300_8car_engineT_Front;
    1: sw_Hankyu_7300_8car_engineT_Back;
}

// 편성그래픽
// 2량
switch (FEAT_TRAINS, SELF, sw_Hankyu_7300_2car, position_in_vehid_chain % 2) {
    0: sw_Hankyu_7300_engineH; //default
    1: sw_Hankyu_7300_engineT;
    }

// 6량
switch (FEAT_TRAINS, SELF, sw_Hankyu_7300_6car, position_in_vehid_chain % 6) {
    0: sw_Hankyu_7300_engineH; //default
    1..3: sw_Hankyu_7300_wagon;
    4: sw_Hankyu_7300_panto_wagon;
    5: sw_Hankyu_7300_engineT;
    }

// 7량
switch (FEAT_TRAINS, SELF, sw_Hankyu_7300_7car, position_in_vehid_chain % 7) {
    0: sw_Hankyu_7300_engineH; //default
    1..4: sw_Hankyu_7300_wagon;
    5: sw_Hankyu_7300_panto_wagon;
    6: sw_Hankyu_7300_engineT;
    }

// 8량
switch (FEAT_TRAINS, SELF, sw_Hankyu_7300_8car, position_in_vehid_chain % 8) {
    0: sw_Hankyu_7300_8car_engineH; //default
    1..4: sw_Hankyu_7300_8car_wagon;
    5: sw_Hankyu_7300_8car_panto_wagon;
    6: sw_Hankyu_7300_8car_wagon;
    7: sw_Hankyu_7300_8car_engineT;
    }

// 편성량
switch (FEAT_TRAINS, SELF, sw_articulated_Hankyu_7300_2car, extra_callback_info1) {
    1: Hankyu_7300_2Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_Hankyu_7300_6car, extra_callback_info1) {
    1..5: Hankyu_7300_6Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_Hankyu_7300_7car, extra_callback_info1) {
    1..6: Hankyu_7300_7Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_Hankyu_7300_8car, extra_callback_info1) {
    1..7: Hankyu_7300_8Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

// 사운드
switch(FEAT_TRAINS, SELF, sw_Hankyu_7300_8Car_Chopper_sound, cargo_subtype) {
    1: sw_Filed_Chopper_Control_sound;
    2: sw_Filed_Chopper_Control_sound;
    3: sw_Filed_Chopper_Control_sound;
    sw_Filed_Chopper_Control_sound;
}

switch(FEAT_TRAINS, SELF, sw_Hankyu_7300_8Car_VVVF_sound, cargo_subtype) {
    1: sw_Filed_Chopper_Control_sound;
    2: sw_Filed_Chopper_Control_sound;
    3: sw_Filed_Chopper_Control_sound;
    4: sw_TOYODENKIIGBT2start_sound;
    sw_Filed_Chopper_Control_sound;
}

switch(FEAT_TRAINS, SELF, sw_Hankyu_7300_8Car_sound, current_year) {
    0..2013: sw_Hankyu_7300_8Car_Chopper_sound;
    sw_Hankyu_7300_8Car_VVVF_sound;
    }

// 차량별 출력
switch(FEAT_TRAINS, SELF, sw_Hankyu_7300_8Car_power_in_custom, cargo_subtype) {
    4: return 4077; // 3040kw 마력<->킬로와트 변환 (마력 = 킬로와트 X 1.341)
       3218; // 2400kw 마력<->킬로와트 변환
}