// 도색명
// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_Gwangjumetro_1000_4car, position_in_vehid_chain % 4) {
    1..2:set_Gwangjumetro_1000_wagon;
    3:set_Gwangjumetro_1000_engineT;
    set_Gwangjumetro_1000_engineH; //default
    }

// 편성량
switch (FEAT_TRAINS, SELF, sw_articulated_Gwangjumetro_1000_4car, extra_callback_info1) {
    1..3: Gwangjumetro_1000_4Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }