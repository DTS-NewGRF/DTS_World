}

// 10량
switch(FEAT_TRAINS, SELF, sw_Seoulmetro_2nd_2000_10car_engineH, cargo_subtype) {
    1: set_Seoulmetro_2nd_2000_engineH;
    set_Seoulmetro_2nd_2000_engineH;
}

