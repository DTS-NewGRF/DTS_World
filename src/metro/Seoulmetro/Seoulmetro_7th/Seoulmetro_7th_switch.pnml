// 도색명
// 10량
// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_Seoulmetro_7th_7000_8car, position_in_vehid_chain % 8) {
    1:set_Seoulmetro_7th_7000_wagon;
    2:set_Seoulmetro_7th_7000_panto_wagon;
    3..5:set_Seoulmetro_7th_7000_wagon;
    6:set_Seoulmetro_7th_7000_panto_wagon;
    7:set_Seoulmetro_7th_7000_engineT;
    set_Seoulmetro_7th_7000_engineH; //default
    }

// 편성량
switch (FEAT_TRAINS, SELF, sw_articulated_Seoulmetro_7th_7000_8car, extra_callback_info1) {
    1..7: Seoulmetro_7th_7000_8Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }