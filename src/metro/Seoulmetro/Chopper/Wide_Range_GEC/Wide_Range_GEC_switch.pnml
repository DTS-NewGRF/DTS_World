/*--------------------------------------------------------------------
스위치
--------------------------------------------------------------------*/
// 도색명
switch(FEAT_TRAINS, SELF, sw_Chopper_Wide_Range_GEC_cargo_subtype_text, cargo_subtype) {
    1: return string(STR_REFIT_LIVERY_Chopper_Wide_Range_GEC_Rheostatic);
    return string(STR_REFIT_LIVERY_Chopper_Wide_Range_GEC_NoRheostatic);
}

// 10량
switch(FEAT_TRAINS, SELF, sw_Chopper_Wide_Range_GEC_10Car_engineH, cargo_subtype) {
    1: set_Chopper_Wide_Range_GEC_Rheostatic_engineH;
    set_Chopper_Wide_Range_GEC_NoRheostatic_engineH;
}

switch(FEAT_TRAINS, SELF, sw_Chopper_Wide_Range_GEC_10Car_wagon, cargo_subtype) {
    1: set_Chopper_Wide_Range_GEC_Rheostatic_wagon;
    set_Chopper_Wide_Range_GEC_NoRheostatic_wagon;
}

switch(FEAT_TRAINS, SELF, sw_Chopper_Wide_Range_GEC_10Car_panto_wagon, cargo_subtype) {
    1: set_Chopper_Wide_Range_GEC_Rheostatic_panto_wagon;
    set_Chopper_Wide_Range_GEC_NoRheostatic_panto_wagon;
}

switch(FEAT_TRAINS, SELF, sw_Chopper_Wide_Range_GEC_10Car_engineT, cargo_subtype) {
    1: set_Chopper_Wide_Range_GEC_Rheostatic_engineT;
    set_Chopper_Wide_Range_GEC_NoRheostatic_engineT;
}

// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_Chopper_Wide_Range_GEC_6Car, position_in_vehid_chain % 6) {
    1:set_Chopper_Wide_Range_GEC_NoRheostatic_wagon;
    2:set_Chopper_Wide_Range_GEC_NoRheostatic_panto_wagon;
    3:set_Chopper_Wide_Range_GEC_NoRheostatic_wagon;
    4:set_Chopper_Wide_Range_GEC_NoRheostatic_panto_wagon;
    5:set_Chopper_Wide_Range_GEC_NoRheostatic_engineT;
    set_Chopper_Wide_Range_GEC_NoRheostatic_engineH; //default
    }

switch (FEAT_TRAINS, SELF, sw_Chopper_Wide_Range_GEC_10Car, position_in_vehid_chain % 10) {
    1:sw_Chopper_Wide_Range_GEC_10Car_wagon;
    2:sw_Chopper_Wide_Range_GEC_10Car_panto_wagon;
    3:sw_Chopper_Wide_Range_GEC_10Car_wagon;
    4:sw_Chopper_Wide_Range_GEC_10Car_wagon;
    5:sw_Chopper_Wide_Range_GEC_10Car_wagon;
    6:sw_Chopper_Wide_Range_GEC_10Car_panto_wagon;
    7:sw_Chopper_Wide_Range_GEC_10Car_wagon;
    8:sw_Chopper_Wide_Range_GEC_10Car_panto_wagon;
    9:sw_Chopper_Wide_Range_GEC_10Car_engineT;
    sw_Chopper_Wide_Range_GEC_10Car_engineH; //default
    }

// 편성량
switch (FEAT_TRAINS, SELF, sw_articulated_Chopper_Wide_Range_GEC_6Car, extra_callback_info1) {
    1..5: Chopper_Wide_Range_GEC_6Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_Chopper_Wide_Range_GEC_10Car, extra_callback_info1) {
    1..9: Chopper_Wide_Range_GEC_10Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }