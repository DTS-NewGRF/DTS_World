// 구매차량 등장년도
switch(FEAT_TRAINS, SELF, sw_Seoulmetro_purchase, current_year) {
    0..1983: set_Seoulmetro_1974_purchase;
    1984..1993: set_Seoulmetro_1984_purchase;
    1994..2004: set_Seoulmetro_1994_purchase;
    2005..2011: set_Seoulmetro_2005_purchase;
    2012..2017: set_Seoulmetro_2012_purchase;
    set_Seoulmetro_2018_purchase;
    }