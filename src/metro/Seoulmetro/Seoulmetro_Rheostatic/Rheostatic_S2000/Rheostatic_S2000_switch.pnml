/*--------------------------------------------------------------------
스위치
--------------------------------------------------------------------*/
// 도색명
switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_Rheostatic_S2000_NoRheostatic);
    1: return string(STR_REFIT_LIVERY_Rheostatic_S2000_Rheostatic);
}

switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_6Car_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_Rheostatic_S2000_NoRheostatic);
    1: return string(STR_REFIT_LIVERY_Rheostatic_S2000_Rheostatic_A);
    2: return string(STR_REFIT_LIVERY_Rheostatic_S2000_Rheostatic_B);
    3: return string(STR_REFIT_LIVERY_Rheostatic_S2000_Rheostatic_C);
}

// 도색그래픽 세팅
// 열차
// 전진방향
// 4량
switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_4Car_engineH_Front, cargo_subtype) {
    0: set_Rheostatic_S2000_NoRheostatic_engineH;
    1: set_Rheostatic_S2000_Rheostatic_engineH_A;
}

switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_4Car_panto_wagon, cargo_subtype) {
    0: set_Rheostatic_S2000_NoRheostatic_panto_wagon;
    1: set_Rheostatic_S2000_Rheostatic_panto_wagon;
}

switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_4Car_engineT_Front, cargo_subtype) {
    0: set_Rheostatic_S2000_NoRheostatic_engineT;
    1: set_Rheostatic_S2000_Rheostatic_engineT_A;
}

// 6량
switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_6Car_engineH_Front, cargo_subtype) {
    0: set_Rheostatic_S2000_NoRheostatic_engineH;
    1: set_Rheostatic_S2000_Rheostatic_engineH_A;
    2: set_Rheostatic_S2000_Rheostatic_engineH_B;
    3: set_Rheostatic_S2000_Rheostatic_engineH_A;
}

switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_6Car_panto_wagon, cargo_subtype) {
    0: set_Rheostatic_S2000_NoRheostatic_panto_wagon;
    1..3: set_Rheostatic_S2000_Rheostatic_panto_wagon;
}

switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_6Car_3wagon, cargo_subtype) {
    0: set_Rheostatic_S2000_NoRheostatic_wagon;
    1..2: set_Rheostatic_S2000_Rheostatic_wagon_TA;
    3: set_Rheostatic_S2000_Rheostatic_wagon_TB;
}

switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_6Car_4wagon, cargo_subtype) {
    0: set_Rheostatic_S2000_NoRheostatic_wagon;
    1..2: set_Rheostatic_S2000_Rheostatic_wagon_TA;
    3: set_Rheostatic_S2000_Rheostatic_wagon_TB;
}

switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_6Car_engineT_Front, cargo_subtype) {
    0: set_Rheostatic_S2000_NoRheostatic_engineT;
    1: set_Rheostatic_S2000_Rheostatic_engineT_A;
    2: set_Rheostatic_S2000_Rheostatic_engineT_B;
    3: set_Rheostatic_S2000_Rheostatic_engineT_A;
}

// 후진방향
// 4량
switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_4Car_engineH_Back, cargo_subtype) {
    0: set_Rheostatic_S2000_NoRheostatic_engineH_Rev;
    1: set_Rheostatic_S2000_Rheostatic_engineH_A_Rev;
}

switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_4Car_engineT_Back, cargo_subtype) {
    0: set_Rheostatic_S2000_NoRheostatic_engineT_Rev;
    1: set_Rheostatic_S2000_Rheostatic_engineT_A_Rev;
}

// 6량
switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_6Car_engineH_Back, cargo_subtype) {
    0: set_Rheostatic_S2000_NoRheostatic_engineH_Rev;
    1: set_Rheostatic_S2000_Rheostatic_engineH_A_Rev;
    2: set_Rheostatic_S2000_Rheostatic_engineH_B_Rev;
    3: set_Rheostatic_S2000_Rheostatic_engineH_A_Rev;
}

switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_6Car_engineT_Back, cargo_subtype) {
    0: set_Rheostatic_S2000_NoRheostatic_engineT_Rev;
    1: set_Rheostatic_S2000_Rheostatic_engineT_A_Rev;
    2: set_Rheostatic_S2000_Rheostatic_engineT_B_Rev;
    3: set_Rheostatic_S2000_Rheostatic_engineT_A_Rev;
}

// 전후진 통합 코드
// 4량
switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_4Car_engineH, train_is_driving_backwards) {
    0: sw_Rheostatic_S2000_4Car_engineH_Front;
    1: sw_Rheostatic_S2000_4Car_engineH_Back;
}

switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_4Car_engineT, train_is_driving_backwards) {
    0: sw_Rheostatic_S2000_4Car_engineT_Front;
    1: sw_Rheostatic_S2000_4Car_engineT_Back;
}

// 6량
switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_6Car_engineH, train_is_driving_backwards) {
    0: sw_Rheostatic_S2000_6Car_engineH_Front;
    1: sw_Rheostatic_S2000_6Car_engineH_Back;
}

switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_6Car_engineT, train_is_driving_backwards) {
    0: sw_Rheostatic_S2000_6Car_engineT_Front;
    1: sw_Rheostatic_S2000_6Car_engineT_Back;
}

// 10량
switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_NoRheostatic_engineH, train_is_driving_backwards) {
    0: set_Rheostatic_S2000_NoRheostatic_engineH;
    1: set_Rheostatic_S2000_NoRheostatic_engineH_Rev;
}

switch(FEAT_TRAINS, SELF, sw_Rheostatic_S2000_NoRheostatic_engineT, train_is_driving_backwards) {
    0: set_Rheostatic_S2000_NoRheostatic_engineT;
    1: set_Rheostatic_S2000_NoRheostatic_engineT_Rev;
}

// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_Rheostatic_S2000_4Car, position_in_vehid_chain % 4) {
    0: sw_Rheostatic_S2000_4Car_engineH; //default
    1..2: sw_Rheostatic_S2000_4Car_panto_wagon;
    3: sw_Rheostatic_S2000_4Car_engineT;
    }

switch (FEAT_TRAINS, SELF, sw_Rheostatic_S2000_6Car, position_in_vehid_chain % 6) {
    0: sw_Rheostatic_S2000_6Car_engineH; //default
    1: sw_Rheostatic_S2000_6Car_panto_wagon;
    2: sw_Rheostatic_S2000_6Car_3wagon;
    3: sw_Rheostatic_S2000_6Car_4wagon;
    4: sw_Rheostatic_S2000_6Car_panto_wagon;
    5: sw_Rheostatic_S2000_6Car_engineT;
    }

switch (FEAT_TRAINS, SELF, sw_Rheostatic_S2000_10Car, position_in_vehid_chain % 10) {
    0: sw_Rheostatic_S2000_NoRheostatic_engineH; //default
    1: set_Rheostatic_S2000_NoRheostatic_panto_wagon;
    2..3: set_Rheostatic_S2000_NoRheostatic_wagon;
    4: set_Rheostatic_S2000_NoRheostatic_panto_wagon;
    5: set_Rheostatic_S2000_NoRheostatic_wagon;
    6: set_Rheostatic_S2000_NoRheostatic_panto_wagon;
    7: set_Rheostatic_S2000_NoRheostatic_wagon;
    8: set_Rheostatic_S2000_NoRheostatic_panto_wagon;
    9: sw_Rheostatic_S2000_NoRheostatic_engineT;
    }

// 편성수
switch (FEAT_TRAINS, SELF, sw_articulated_Rheostatic_S2000_4Car, extra_callback_info1) {
    1..3: Rheostatic_S2000_4Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_Rheostatic_S2000_6Car, extra_callback_info1) {
    1..5: Rheostatic_S2000_6Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_Rheostatic_S2000_10Car, extra_callback_info1) {
    1..9: Rheostatic_S2000_10Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }