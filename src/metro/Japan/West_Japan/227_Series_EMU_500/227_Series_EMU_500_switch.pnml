/*--------------------------------------------------------------------
스위치
--------------------------------------------------------------------*/
// 도색명
switch(FEAT_TRAINS, SELF, sw_West_Japan_227_EMU_500_2Car_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_West_Japan_227_R_Atype);
    1: return string(STR_REFIT_LIVERY_West_Japan_227_R_Btype);
    2: return string(STR_REFIT_LIVERY_West_Japan_227_H_Atype);
    3: return string(STR_REFIT_LIVERY_West_Japan_227_H_Btype);
}

switch(FEAT_TRAINS, SELF, sw_West_Japan_227_EMU_500_3Car_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_West_Japan_227_L_Atype);
    1: return string(STR_REFIT_LIVERY_West_Japan_227_L_Btype);
}

// 도색그래픽 세팅
// 열차
// 전진방향
switch(FEAT_TRAINS, SELF, sw_West_Japan_227_EMU_500_engineH_Front, cargo_subtype) {
    0..1: set_227_Series_EMU_500_engineH;
    2..3: set_227_Series_EMU_500_engineH_Panto2;
}

// 후진방향
switch(FEAT_TRAINS, SELF, sw_West_Japan_227_EMU_500_engineH_Back, cargo_subtype) {
    0..1: set_227_Series_EMU_500_engineH_Rev;
    2..3: set_227_Series_EMU_500_engineH_Panto2_Rev;
}

// 전후진 통합 코드
// 2량
switch(FEAT_TRAINS, SELF, sw_West_Japan_227_EMU_500_engineH, train_is_driving_backwards) {
    0: sw_West_Japan_227_EMU_500_engineH_Front;
    1: sw_West_Japan_227_EMU_500_engineH_Back;
}

// 3량
switch(FEAT_TRAINS, SELF, sw_227_Series_EMU_500_engineH, train_is_driving_backwards) {
    0: set_227_Series_EMU_500_engineH;
    1: set_227_Series_EMU_500_engineH_Rev;
}

switch(FEAT_TRAINS, SELF, sw_227_Series_EMU_500_engineT, train_is_driving_backwards) {
    0: set_227_Series_EMU_500_engineT;
    1: set_227_Series_EMU_500_engineT_Rev;
}

// 편성그래픽
// 2량
switch (FEAT_TRAINS, SELF, sw_West_Japan_227_EMU_500_2car, position_in_vehid_chain % 2) {
    0: sw_West_Japan_227_EMU_500_engineH; //default
    1: sw_227_Series_EMU_500_engineT;
    }

// 3량
switch (FEAT_TRAINS, SELF, sw_West_Japan_227_EMU_500_3car, position_in_vehid_chain % 3) {
    0: sw_227_Series_EMU_500_engineH; //default
    1: set_227_Series_EMU_500_wagon_M;
    2: sw_227_Series_EMU_500_engineT;
    }

// 편성량
switch (FEAT_TRAINS, SELF, sw_articulated_West_Japan_227_EMU_500_2car, extra_callback_info1) {
    1: WJapan_227_Series_EMU_500_2Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_West_Japan_227_EMU_500_3car, extra_callback_info1) {
    1..2: WJapan_227_Series_EMU_500_3Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

// 사운드
switch(FEAT_TRAINS, SELF, sw_West_Japan_227_EMU_500_2Car_sound, cargo_subtype) {
    1: sw_TOYODENKIIGBTStart_sound;
    2: sw_TOSHIBAIGBTJ4start_sound;
    3: sw_TOYODENKIIGBTStart_sound;
    sw_TOSHIBAIGBTJ4start_sound;
}

switch(FEAT_TRAINS, SELF, sw_West_Japan_227_EMU_500_3Car_sound, cargo_subtype) {
    1: sw_TOYODENKIIGBTStart_sound;
    sw_TOSHIBAIGBTJ4start_sound;
}