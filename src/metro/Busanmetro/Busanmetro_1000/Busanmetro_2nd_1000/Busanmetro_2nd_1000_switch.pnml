/*--------------------------------------------------------------------
스위치
--------------------------------------------------------------------*/
// 도색명
switch(FEAT_TRAINS, SELF, sw_Busanmetro_2nd_1000_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_Busanmetro_2nd_1000_G1);
    1: return string(STR_REFIT_LIVERY_Busanmetro_2nd_1000_G2);
    2: return string(STR_REFIT_LIVERY_Busanmetro_2nd_1000_G3);
}

// 도색그래픽 세팅
// 열차
// 전진방향
switch(FEAT_TRAINS, SELF, sw_Busanmetro_2nd_1000_engineH_Front, cargo_subtype) {
    0..1: set_Busanmetro_2nd_1000_G1_engineH;
    2: set_Busanmetro_2nd_1000_G2_engineH;
}

switch(FEAT_TRAINS, SELF, sw_Busanmetro_2nd_1000_panto_wagon, cargo_subtype) {
    0..1: set_Busanmetro_2nd_1000_G1_panto_wagon;
    2: set_Busanmetro_2nd_1000_G2_panto_wagon;
}

switch(FEAT_TRAINS, SELF, sw_Busanmetro_2nd_1000_wagon, cargo_subtype) {
    0..1: set_Busanmetro_2nd_1000_G1_wagon;
    2: set_Busanmetro_2nd_1000_G2_wagon;
}

switch(FEAT_TRAINS, SELF, sw_Busanmetro_2nd_1000_engineT_Front, cargo_subtype) {
    0..1: set_Busanmetro_2nd_1000_G1_engineT;
    2: set_Busanmetro_2nd_1000_G2_engineT;
}

// 후진방향
switch(FEAT_TRAINS, SELF, sw_Busanmetro_2nd_1000_engineH_Back, cargo_subtype) {
    0..1: set_Busanmetro_2nd_1000_G1_engineH_Rev;
    2: set_Busanmetro_2nd_1000_G2_engineH_Rev;
}

switch(FEAT_TRAINS, SELF, sw_Busanmetro_2nd_1000_engineT_Back, cargo_subtype) {
    0..1: set_Busanmetro_2nd_1000_G1_engineT_Rev;
    2: set_Busanmetro_2nd_1000_G2_engineT_Rev;
}

// 전후진 통합 코드
switch(FEAT_TRAINS, SELF, sw_Busanmetro_2nd_1000_engineH, train_is_driving_backwards) {
    0: sw_Busanmetro_2nd_1000_engineH_Front;
    1: sw_Busanmetro_2nd_1000_engineH_Back;
}

switch(FEAT_TRAINS, SELF, sw_Busanmetro_2nd_1000_engineT, train_is_driving_backwards) {
    0: sw_Busanmetro_2nd_1000_engineT_Front;
    1: sw_Busanmetro_2nd_1000_engineT_Back;
}

// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_Busanmetro_2nd_1000_8car, position_in_vehid_chain % 8) {
    0: sw_Busanmetro_2nd_1000_engineH; //default
    1: sw_Busanmetro_2nd_1000_wagon;
    2: sw_Busanmetro_2nd_1000_panto_wagon;
    3..5: sw_Busanmetro_2nd_1000_wagon;
    6: sw_Busanmetro_2nd_1000_panto_wagon;
    7: sw_Busanmetro_2nd_1000_engineT;
    }

// 편성량
switch (FEAT_TRAINS, SELF, sw_articulated_Busanmetro_2nd_1000_8car, extra_callback_info1) {
    1..7: Busanmetro_2st_1000_8Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

// 사운드
switch(FEAT_TRAINS, SELF, sw_Busanmetro_2nd_1000_sound, cargo_subtype) {
    0: sw_HYUNDAIROTEMIGBTIPM1Kstart_Busanmetro_sound;
    1..2: sw_TOSHIBAIGBTPMSMstart_Busanmetro_sound;
}