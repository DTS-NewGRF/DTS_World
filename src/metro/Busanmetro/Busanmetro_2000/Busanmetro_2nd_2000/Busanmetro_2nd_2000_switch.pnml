// 도색명
// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_Busanmetro_2nd_2000_6car, position_in_vehid_chain % 6) {
    1:set_Busanmetro_2nd_2000_wagon;
    2:set_Busanmetro_2nd_2000_panto_wagon;
    3:set_Busanmetro_2nd_2000_wagon;
    4:set_Busanmetro_2nd_2000_panto_wagon;
    5:set_Busanmetro_2nd_2000_engineT;
    set_Busanmetro_2nd_2000_engineH; //default
    }

// 편성량
switch (FEAT_TRAINS, SELF, sw_articulated_Busanmetro_2nd_2000_6car, extra_callback_info1) {
    1..5: Busanmetro_2nd_2000_6Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }