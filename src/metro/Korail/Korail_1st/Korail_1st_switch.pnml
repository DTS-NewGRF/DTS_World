// 전후진 통합 코드
// 6량
switch(FEAT_TRAINS, SELF, sw_Korail_1st_6Car_engineH, train_is_driving_backwards) {
    0: sw_Korail_1st_6Car_engineH_Front;
    1: sw_Korail_1st_6Car_engineH_Back;
}

switch(FEAT_TRAINS, SELF, sw_Korail_1st_6Car_engineT, train_is_driving_backwards) {
    0: sw_Korail_1st_6Car_engineT_Front;
    1: sw_Korail_1st_6Car_engineT_Back;
}

