    1: sw_Korail_1st_10Car_engineH_Back;
}

switch(FEAT_TRAINS, SELF, sw_Korail_1st_10Car_engineT, train_is_driving_backwards) {
    0: sw_Korail_1st_10Car_engineT_Front;
    1: sw_Korail_1st_10Car_engineT_Back;
}

// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_Korail_1st_4car, position_in_vehid_chain % 4) {
    0: set_Korail_1st_319K_engineH; //default
    1..2: set_Korail_1st_319K_panto_wagon;
    3: set_Korail_1st_319K_engineT;
    }

switch (FEAT_TRAINS, SELF, sw_Korail_1st_6car, position_in_vehid_chain % 6) {
    0: sw_Korail_1st_6Car_engineH; //default
    1: sw_Korail_1st_6Car_wagon;
    2: sw_Korail_1st_6Car_panto_wagon;
    3: sw_Korail_1st_6Car_wagon;
    4: sw_Korail_1st_6Car_panto_wagon;
    5: sw_Korail_1st_6Car_engineT;
    }

switch (FEAT_TRAINS, SELF, sw_Korail_1st_10car, position_in_vehid_chain % 10) {
    0: sw_Korail_1st_10Car_engineH; //default
    1: sw_Korail_1st_10Car_wagon_2_8Car;
    2: sw_Korail_1st_10Car_panto_wagon;
    3: sw_Korail_1st_10Car_wagon_4_7Car;
    4: sw_Korail_1st_10Car_panto_wagon;
    5: sw_Korail_1st_10Car_wagon_6Car;
    6: sw_Korail_1st_10Car_wagon_4_7Car;
    7: sw_Korail_1st_10Car_wagon_2_8Car;
    8: sw_Korail_1st_10Car_panto_wagon;
    9: sw_Korail_1st_10Car_engineT;
    }

// 편성수
switch (FEAT_TRAINS, SELF, sw_articulated_Korail_1st_4car, extra_callback_info1) {
    1..3: Korail_1st_4car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_Korail_1st_6car, extra_callback_info1) {
    1..5: Korail_1st_6car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_Korail_1st_10car, extra_callback_info1) {
    1..9: Korail_1st_10car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

// 사운드
switch(FEAT_TRAINS, SELF, sw_Korail_1st_4Car_sound, cargo_subtype) {
    0: sw_TOSHIBAGTOKStrart_sound;
    1: sw_TOSHIBAIGBTKStart_sound;
}

switch(FEAT_TRAINS, SELF, sw_Korail_1st_6Car_sound, cargo_subtype) {
    0..1: sw_TOSHIBAGTOKStrart_sound;
    2..3: sw_TOSHIBAIGBTKStart_sound;
}

switch(FEAT_TRAINS, SELF, sw_Korail_1st_10Car_sound, cargo_subtype) {
    0: sw_TOSHIBAGTOKStrart_sound;
    1..2: sw_TOSHIBAIGBTKStart_sound;
    3..6: sw_TOSHIBAGTOKStrart_sound;
    7..8: sw_MITSUBISHIGTOKstart_sound;
    9: sw_TOSHIBAIGBTKStart_sound;
}