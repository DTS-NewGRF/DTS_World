/*--------------------------------------------------------------------
스위치
--------------------------------------------------------------------*/
// 도색명
switch(FEAT_TRAINS, SELF, sw_Korail_First_10car_cargo_subtype_text, cargo_subtype) {
    1: return string(STR_REFIT_LIVERY_Korail_First_K1000_Initial_Aircon_A);
    2: return string(STR_REFIT_LIVERY_Korail_First_K1000_Initial_Aircon_B);
    3: return string(STR_REFIT_LIVERY_Korail_First_K1000_Old_A);
    4: return string(STR_REFIT_LIVERY_Korail_First_K1000_Old_B);
    return string(STR_REFIT_LIVERY_Korail_First_K1000_Initial);
}

// 10량
switch(FEAT_TRAINS, SELF, sw_Korail_First_engineH, cargo_subtype) {
    1..2: set_Korail_K1000_Initial_Aircon_engineH;
    3..4: set_Korail_K1000_Old_engineH;
    set_Korail_K1000_Initial_engineH;
}

switch(FEAT_TRAINS, SELF, sw_Korail_First_wagon_MAMB, cargo_subtype) {
    1: set_Korail_K1000_Initial_Aircon_MA_wagon;
    2: set_Korail_K1000_Initial_Aircon_MB_wagon;
    3: set_Korail_K1000_Old_MA_wagon;
    4: set_Korail_K1000_Old_MB_wagon;
    set_Korail_K1000_Initial_wagon;
}

switch(FEAT_TRAINS, SELF, sw_Korail_First_panto_wagon_MAMB, cargo_subtype) {
    1: set_Korail_K1000_Initial_Aircon_MA_panto_wagon;
    2: set_Korail_K1000_Initial_Aircon_MB_panto_wagon;
    3: set_Korail_K1000_Old_MA_panto_wagon;
    4: set_Korail_K1000_Old_MB_panto_wagon;
    set_Korail_K1000_Initial_panto_wagon;
}

switch(FEAT_TRAINS, SELF, sw_Korail_First_wagon_MA, cargo_subtype) {
    1..2: set_Korail_K1000_Initial_Aircon_MA_wagon;
    3..4: set_Korail_K1000_Old_MA_wagon;
    set_Korail_K1000_Initial_wagon;
}

switch(FEAT_TRAINS, SELF, sw_Korail_First_engineT, cargo_subtype) {
    1..2: set_Korail_K1000_Initial_Aircon_engineT;
    3..4: set_Korail_K1000_Old_engineT;
    set_Korail_K1000_Initial_engineT;
}

// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_Korail_First_4car, position_in_vehid_chain % 4) {
    1:set_Korail_K1000_Initial_wagon;
    2:set_Korail_K1000_Initial_panto_wagon;
    3:set_Korail_K1000_Initial_engineT;
    set_Korail_K1000_Initial_engineH; //default
    }

switch (FEAT_TRAINS, SELF, sw_Korail_First_6car, position_in_vehid_chain % 6) {
    1:set_Korail_K1000_Initial_wagon;
    2:set_Korail_K1000_Initial_panto_wagon;
    3:set_Korail_K1000_Initial_wagon;
    4:set_Korail_K1000_Initial_panto_wagon;
    5:set_Korail_K1000_Initial_engineT;
    set_Korail_K1000_Initial_engineH; //default
    }

switch (FEAT_TRAINS, SELF, sw_Korail_First_8car, position_in_vehid_chain % 8) {
    1:set_Korail_K1000_Initial_wagon;
    2:set_Korail_K1000_Initial_panto_wagon;
    3:set_Korail_K1000_Initial_wagon;
    4:set_Korail_K1000_Initial_panto_wagon;
    5:set_Korail_K1000_Initial_wagon;
    6:set_Korail_K1000_Initial_panto_wagon;
    7:set_Korail_K1000_Initial_engineT;
    set_Korail_K1000_Initial_engineH; //default
    }

switch (FEAT_TRAINS, SELF, sw_Korail_First_10car, position_in_vehid_chain % 10) {
    1:sw_Korail_First_wagon_MAMB;
    2:sw_Korail_First_panto_wagon_MAMB;
    3:sw_Korail_First_wagon_MA;
    4:sw_Korail_First_wagon_MAMB;
    5:sw_Korail_First_panto_wagon_MAMB;
    6:sw_Korail_First_wagon_MA;
    7:sw_Korail_First_wagon_MAMB;
    8:sw_Korail_First_panto_wagon_MAMB;
    9:sw_Korail_First_engineT;
    sw_Korail_First_engineH; //default
    }

// 편성량
switch (FEAT_TRAINS, SELF, sw_articulated_Korail_First_4car, extra_callback_info1) {
    1..3: Korail_First_4Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_Korail_First_6car, extra_callback_info1) {
    1..5: Korail_First_6Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_Korail_First_8car, extra_callback_info1) {
    1..7: Korail_First_8Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_Korail_First_10car, extra_callback_info1) {
    1..9: Korail_First_10Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }