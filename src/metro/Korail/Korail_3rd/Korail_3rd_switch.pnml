// 도색명
switch(FEAT_TRAINS, SELF, sw_Korail_3rd_4car_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_Korail_3rd_ST_DOB);
    1: return string(STR_REFIT_LIVERY_Korail_3rd_ST_331K_DOB); // 스테인레스 더블암 331K
    2: return string(STR_REFIT_LIVERY_Korail_3rd_ST_SI);       // 스테인레스 싱글암
    3: return string(STR_REFIT_LIVERY_Korail_3rd_371_381);     // 경강선, 동해선
}

switch(FEAT_TRAINS, SELF, sw_Korail_3rd_6car_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_Korail_3rd_ST_DOB);
    1: return string(STR_REFIT_LIVERY_Korail_3rd_ST_SI);       // 스테인레스 싱글암
}

switch(FEAT_TRAINS, SELF, sw_Korail_3rd_8car_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_Korail_3rd_ST_DOB);
    1: return string(STR_REFIT_LIVERY_Korail_3rd_AL_331K_Toshiba);     // 알루미늄 331K
    2: return string(STR_REFIT_LIVERY_Korail_3rd_AL_361K_A);   // 알루미늄 361K 출입문 도색 (스프라이트 311의 A)
    3: return string(STR_REFIT_LIVERY_Korail_3rd_AL_361K_B);   // 알루미늄 361K 줄무늬 도색
    4: return string(STR_REFIT_LIVERY_Korail_3rd_Bike);        // 코레일 3세대 VVVF 자전거 도색
    5: return string(STR_REFIT_LIVERY_Korail_3rd_AL_331K_Woojin);     // 알루미늄 331K
}

switch(FEAT_TRAINS, SELF, sw_Korail_3rd_10car_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_Korail_3rd_ST_DOB);
