    2: return string(STR_REFIT_LIVERY_Korail_3rd_AL_331K_Toshiba);     // 알루미늄 311K
    3: return string(STR_REFIT_LIVERY_Korail_3rd_Civil_complaint_365); // 코레일 3세대 VVVF 민원전철365 도색
}

