/*--------------------------------------------------------------------
스위치
--------------------------------------------------------------------*/
// 도색명
switch(FEAT_TRAINS, SELF, sw_Incheonmetro_1000_1st_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_Incheonmetro_1000_1st_New);
    1: return string(STR_REFIT_LIVERY_Incheonmetro_1000_1st_Old_IGBT_1lv);
    2: return string(STR_REFIT_LIVERY_Incheonmetro_1000_1st_Old_IGBT_2lv);
}

// 도색그래픽 세팅
// 열차
// 전진방향
switch(FEAT_TRAINS, SELF, sw_Incheonmetro_1000_1st_engineH_Front, cargo_subtype) {
    0: set_Incheonmetro_1000_1st_New_engineH;
    1..2: set_Incheonmetro_1000_1st_Old_engineH;
}

switch(FEAT_TRAINS, SELF, sw_Incheonmetro_1000_1st_panto_wagon, cargo_subtype) {
    0: set_Incheonmetro_1000_1st_New_panto_wagon;
    1..2: set_Incheonmetro_1000_1st_Old_panto_wagon;
}

switch(FEAT_TRAINS, SELF, sw_Incheonmetro_1000_1st_wagon, cargo_subtype) {
    0: set_Incheonmetro_1000_1st_New_wagon;
    1..2: set_Incheonmetro_1000_1st_Old_wagon;
}

switch(FEAT_TRAINS, SELF, sw_Incheonmetro_1000_1st_engineT_Front, cargo_subtype) {
    0: set_Incheonmetro_1000_1st_New_engineT;
    1..2: set_Incheonmetro_1000_1st_Old_engineT;
}

// 후진방향
switch(FEAT_TRAINS, SELF, sw_Incheonmetro_1000_1st_engineH_Back, cargo_subtype) {
    0: set_Incheonmetro_1000_1st_New_engineH_Rev;
    1..2: set_Incheonmetro_1000_1st_Old_engineH_Rev;
}

switch(FEAT_TRAINS, SELF, sw_Incheonmetro_1000_1st_engineT_Back, cargo_subtype) {
    0: set_Incheonmetro_1000_1st_New_engineT_Rev;
    1..2: set_Incheonmetro_1000_1st_Old_engineT_Rev;
}

// 전후진 통합 코드
switch(FEAT_TRAINS, SELF, sw_Incheonmetro_1000_1st_engineH, train_is_driving_backwards) {
    0: sw_Incheonmetro_1000_1st_engineH_Front;
    1: sw_Incheonmetro_1000_1st_engineH_Back;
}

switch(FEAT_TRAINS, SELF, sw_Incheonmetro_1000_1st_engineT, train_is_driving_backwards) {
    0: sw_Incheonmetro_1000_1st_engineT_Front;
    1: sw_Incheonmetro_1000_1st_engineT_Back;
}

// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_Incheonmetro_1000_1st_8car, position_in_vehid_chain % 8) {
    0: sw_Incheonmetro_1000_1st_engineH; //default
    1..2: sw_Incheonmetro_1000_1st_panto_wagon;
    3..4: sw_Incheonmetro_1000_1st_wagon;
    5..6: sw_Incheonmetro_1000_1st_panto_wagon;
    7: sw_Incheonmetro_1000_1st_engineT;
    }

// 편성량
switch (FEAT_TRAINS, SELF, sw_articulated_Incheonmetro_1000_1st_8car, extra_callback_info1) {
    1..7: Incheonmetro_1000_1st_8Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

// 사운드
switch(FEAT_TRAINS, SELF, sw_Incheonmetro_1000_1st_sound, cargo_subtype) {
    0: sw_WOOJIN_IGBT_1start_sound;
    1: sw_ALSTOM_IGBT_Start_sound;
    2: sw_WOOJIN_IGBT_1start_sound;
}