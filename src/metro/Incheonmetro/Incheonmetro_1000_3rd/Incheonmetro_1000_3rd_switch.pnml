/*--------------------------------------------------------------------
스위치
--------------------------------------------------------------------*/
// 전후진 통합 코드
switch(FEAT_TRAINS, SELF, sw_Incheonmetro_1000_3rd_engineH, train_is_driving_backwards) {
    0: set_Incheonmetro_1000_3rd_engineH;
    1: set_Incheonmetro_1000_3rd_engineH_Rev;
}

switch(FEAT_TRAINS, SELF, sw_Incheonmetro_1000_3rd_engineT, train_is_driving_backwards) {
    0: set_Incheonmetro_1000_3rd_engineT;
    1: set_Incheonmetro_1000_3rd_engineT_Rev;
}

// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_Incheonmetro_1000_3rd_8car, position_in_vehid_chain % 8) {
    0: sw_Incheonmetro_1000_3rd_engineH; //default
    1: set_Incheonmetro_1000_3rd_wagon;
    2: set_Incheonmetro_1000_3rd_panto_wagon;
    3..5: set_Incheonmetro_1000_3rd_wagon;
    6: set_Incheonmetro_1000_3rd_panto_wagon;
    7: sw_Incheonmetro_1000_3rd_engineT;
    }

// 편성수
switch (FEAT_TRAINS, SELF, sw_articulated_Incheonmetro_1000_3rd_8car, extra_callback_info1) {
    1..7: Incheonmetro_1000_3rd_8Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }