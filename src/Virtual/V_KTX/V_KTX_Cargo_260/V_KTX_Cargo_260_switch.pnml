/*--------------------------------------------------------------------
스위치
--------------------------------------------------------------------*/
// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_V_KTX_Cargo_260_6car, position_in_vehid_chain % 6) {
    1..5:set_Deleted_wagon;
    set_Deleted_engineH; //default
    }

// 12량
switch (FEAT_TRAINS, SELF, sw_V_KTX_Cargo_260_12car, position_in_vehid_chain % 12) {
    1..11:set_Deleted_wagon;
    set_Deleted_engineH; //default
    }

// 편성량
switch (FEAT_TRAINS, SELF, sw_articulated_V_KTX_Cargo_260_6car, extra_callback_info1) {
    1..5: V_KTX_Cargo_260_6Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_V_KTX_Cargo_260_12car, extra_callback_info1) {
    1..11: V_KTX_Cargo_260_12Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }