    4: return string(STR_REFIT_LIVERY_V_KTX_Eum_MD);
    5: return string(STR_REFIT_LIVERY_V_KTX_Eum_SM1);
    6: return string(STR_REFIT_LIVERY_V_KTX_Eum_SM2);
    7: return string(STR_REFIT_LIVERY_V_KTX_Eum_SM3);
    return string(STR_REFIT_LIVERY_KTX_Eum);
}

