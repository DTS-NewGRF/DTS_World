//도색명
switch(FEAT_TRAINS, SELF, sw_V_KTX_Eum_6car_cargo_subtype_text, cargo_subtype) {
    1: return string(STR_REFIT_LIVERY_V_KTX_Eum_BK);
    2: return string(STR_REFIT_LIVERY_V_KTX_Eum_MD);
    3: return string(STR_REFIT_LIVERY_V_KTX_Eum_SM1);
    4: return string(STR_REFIT_LIVERY_V_KTX_Eum_SM2);
    5: return string(STR_REFIT_LIVERY_V_KTX_Eum_SM3);
    return string(STR_REFIT_LIVERY_V_KTX_Eum_W);
}

