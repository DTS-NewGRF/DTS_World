    3:sw_V_Nuriro_DD_engineH_r;
    sw_V_Nuriro_DD_engineT_r; //default
    }

switch(FEAT_TRAINS, SELF, sw_V_Nuriro_DD_4car_flipped, vehicle_is_flipped){
    0: sw_V_Nuriro_DD_4car_r;
    sw_V_Nuriro_DD_4car;
}

switch(FEAT_TRAINS, PARENT, sw_V_Nuriro_DD_4car_reversed, vehicle_is_reversed){
    0: sw_V_Nuriro_DD_4car;
    sw_V_Nuriro_DD_4car_flipped;
}

