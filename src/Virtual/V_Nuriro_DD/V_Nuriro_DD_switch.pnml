// 편성그래픽
// 4량
switch (FEAT_TRAINS, SELF, sw_V_Nuriro_DD_4car, position_in_vehid_chain % 4) {
    1:sw_V_Nuriro_DD_wagon_T1;
    2:sw_V_Nuriro_DD_wagon_T2;
    3:sw_V_Nuriro_DD_engineT;
    sw_V_Nuriro_DD_engineH; //default
    }

