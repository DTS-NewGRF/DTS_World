// 도색
switch(FEAT_TRAINS, SELF, sw_V_Nuriro_DD_cargo_subtype_text, cargo_subtype) {
    1: return string(STR_REFIT_LIVERY_Nuriro_DD_New);
    2: return string(STR_REFIT_LIVERY_Nuriro_DD_O_Train);
    3: return string(STR_REFIT_LIVERY_Nuriro_DD_ITX_Saemaeul);
    return string(STR_REFIT_LIVERY_Nuriro_DD_Old);
}

// 4량
switch(FEAT_TRAINS, SELF, sw_V_Nuriro_DD_engineH, cargo_subtype) {
    1: set_V_Nuriro_DD_New_engineH;
    2: set_V_Nuriro_DD_O_Train_engineH;
    3: set_V_Nuriro_DD_ITX_Saemaeul_engineH;
    set_V_Nuriro_DD_Old_engineH;
}

