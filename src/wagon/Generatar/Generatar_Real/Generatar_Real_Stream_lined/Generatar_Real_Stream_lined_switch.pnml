//도색
switch(FEAT_TRAINS, SELF, sw_Generatar_Real_Stream_lined_cargo_subtype_text, cargo_subtype) {
     0: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_LS);
     1: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_SS);
     2: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_OLS);
     3: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_OLM);
     4: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_OSS);
     5: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_OJS);
     6: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_NLS);
     7: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_NLM);
     8: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_NSS);
     9: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_NJS);
    10: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_HR);
    11: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_MR);
    12: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_SB);
    13: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_SP);
    14: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_JA);
    15: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_WG);
    16: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_WN);
    17: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_NS);
    18: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_NA);
    19: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_NG);
    20: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_GY);
    21: return string(STR_REFIT_LIVERY_Generatar_Real_Stream_lined_LMM);
    return CB_RESULT_NO_TEXT;
}

//열차
switch(FEAT_TRAINS, SELF, sw_Generatar_Real_Stream_lined_wagon, cargo_subtype) {
     1: set_Generatar_Real_Stream_lined_SS;
     2: set_Generatar_Real_Stream_lined_OLS;
     3: set_Generatar_Real_Stream_lined_OLM;
     4: set_Generatar_Real_Stream_lined_OSS;
     5: set_Generatar_Real_Stream_lined_OJS;
     6: set_Generatar_Real_Stream_lined_NLS;
     7: set_Generatar_Real_Stream_lined_NLM;
     8: set_Generatar_Real_Stream_lined_NSS;
     9: set_Generatar_Real_Stream_lined_NJS;
    10: set_Generatar_Real_Stream_lined_HR;
    11: set_Generatar_Real_Stream_lined_MR;
    12: set_Generatar_Real_Stream_lined_SB;
    13: set_Generatar_Real_Stream_lined_SP;
    14: set_Generatar_Real_Stream_lined_JA;
    15: set_Generatar_Real_Stream_lined_WG;
    16: set_Generatar_Real_Stream_lined_WN;
    17: set_Generatar_Real_Stream_lined_NS;
    18: set_Generatar_Real_Stream_lined_NA;
    19: set_Generatar_Real_Stream_lined_NG;
    20: set_Generatar_Real_Stream_lined_GY;
    21: set_Generatar_Real_Stream_lined_LMM;
    set_Generatar_Real_Stream_lined_LS;
}

// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_Generatar_Real_Stream_lined_wagon_1Car, position_in_vehid_chain % 1) {
