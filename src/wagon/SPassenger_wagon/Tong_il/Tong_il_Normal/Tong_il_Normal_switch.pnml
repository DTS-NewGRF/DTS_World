//도색
switch(FEAT_TRAINS, SELF, sw_Tong_il_Normal_cargo_subtype_text, cargo_subtype) {
     0: return string(STR_REFIT_LIVERY_Tong_il_Normal_T_1963);
     1: return string(STR_REFIT_LIVERY_Tong_il_Normal_T_1968);
     2: return string(STR_REFIT_LIVERY_Tong_il_Normal_T_1974);
     3: return string(STR_REFIT_LIVERY_Tong_il_Normal_FD_1963);
     4: return string(STR_REFIT_LIVERY_Tong_il_Normal_B_1962_U);
     5: return string(STR_REFIT_LIVERY_Tong_il_Normal_T2_1963_1968);
     6: return string(STR_REFIT_LIVERY_Tong_il_Normal_T2_1974);
     7: return string(STR_REFIT_LIVERY_Tong_il_Normal_FD_1963_T);
     8: return string(STR_REFIT_LIVERY_Tong_il_Normal_T2_1984);
     9: return string(STR_REFIT_LIVERY_Tong_il_Normal_TO_1989);
    10: return string(STR_REFIT_LIVERY_Tong_il_Normal_T_1994);
    11: return string(STR_REFIT_LIVERY_Tong_il_Normal_TO1);
    12: return string(STR_REFIT_LIVERY_Tong_il_Normal_TO2);
    13: return string(STR_REFIT_LIVERY_Tong_il_Normal_T_1997);
    return CB_RESULT_NO_TEXT;
}

//열차
switch(FEAT_TRAINS, SELF, sw_Tong_il_Normal_wagon, cargo_subtype) {
     1: set_Tong_il_Normal_T_1968;
     2: set_Tong_il_Normal_T_1974;
     3: set_Tong_il_Normal_FD_1963;
     4: set_Tong_il_Normal_B_1962_U;
     5: set_Tong_il_Normal_T2_1963_1968;
     6: set_Tong_il_Normal_T2_1974;
     7: set_Tong_il_Normal_FD_1963_T;
     8: set_Tong_il_Normal_T2_1984;
     9: set_Tong_il_Normal_TO_1989;
    10: set_Tong_il_Normal_T_1994;
    11: set_Tong_il_Normal_TO1;
    12: set_Tong_il_Normal_TO2;
    13: set_Tong_il_Normal_T_1997;
    set_Tong_il_Normal_T_1963;
}