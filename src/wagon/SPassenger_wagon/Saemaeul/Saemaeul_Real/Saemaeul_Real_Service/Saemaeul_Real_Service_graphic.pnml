// 구매차량 등장년도
switch(FEAT_TRAINS, SELF, sw_Saemaeul_Real_Service_purchase, current_year) {
    0..1985: set_Saemaeul_Real_Service_1969_purchase;
    1986..1989: set_Saemaeul_Real_Service_1986_purchase;
    1990..1994: set_Saemaeul_Real_Service_1990_purchase;
    1995..2005: set_Saemaeul_Real_Service_1995_purchase;
    2006: set_Saemaeul_Real_Service_2006_purchase;
    set_Saemaeul_Real_Service_2007_purchase;
    }