스위치
--------------------------------------------------------------------*/
switch (FEAT_TRAINS, SELF, sw_TLX_wagon, position_in_vehid_chain % 5) {
    1:set_TLX_2wagon;
    2:set_TLX_3wagon;
    3:set_TLX_4wagon;
    4:set_TLX_5wagon;
    set_TLX_1wagon; //default
    }

switch (FEAT_TRAINS, SELF, sw_articulated_TLX_wagon_5car, extra_callback_info1) {
    1..4: TLX_5Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }