//도색
switch(FEAT_TRAINS, SELF, Pidulgi_Service_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_Pidulgi_Service_C_MADE_1936);
    1: return string(STR_REFIT_LIVERY_Pidulgi_Service_1964);
    return CB_RESULT_NO_TEXT;
}

//열차
switch(FEAT_TRAINS, SELF, sw_Pidulgi_Service_wagon, cargo_subtype) {
    1: set_Pidulgi_Service_1964;
    set_Pidulgi_Service_C_MADE_1936;
}

// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_Pidulgi_Service_wagon_1Car, position_in_vehid_chain % 1) {
    sw_Pidulgi_Service_wagon; //default
    }