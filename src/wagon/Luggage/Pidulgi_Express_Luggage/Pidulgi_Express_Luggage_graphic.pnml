// 구매차량 등장년도
switch(FEAT_TRAINS, SELF, sw_Pidulgi_Express_Luggage_purchase, current_year) {
    0..1961: set_Pidulgi_Express_Luggage_1960_purchase;
    1962..1967: set_Pidulgi_Express_Luggage_1962_purchase;
    1968..1983: set_Pidulgi_Express_Luggage_1968_purchase;
    1984..1993: set_Pidulgi_Express_Luggage_1984_purchase;
    set_Pidulgi_Express_Luggage_1994_purchase;
    }