//도색
switch(FEAT_TRAINS, SELF, sw_Express_Post_Car_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_Express_Post_Car_POST_M_1993);
    1: return string(STR_REFIT_LIVERY_Express_Post_Car_POST_M_2005);
    return CB_RESULT_NO_TEXT;
}

//열차
switch(FEAT_TRAINS, SELF, sw_Express_Post_Car_wagon, cargo_subtype) {
    1: set_Express_Post_Car_POST_M_2005;
    set_Express_Post_Car_POST_M_1993;
}

// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_Express_Post_Car_wagon_1Car, position_in_vehid_chain % 1) {
    sw_Express_Post_Car_wagon; //default
    }