/*--------------------------------------------------------------------
스위치
--------------------------------------------------------------------*/
// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_DTX_Glory_20car, position_in_vehid_chain % 20) {
    1..19:set_Deleted_wagon;
    set_Deleted_engineH; //default
    }

// 편성량
switch (FEAT_TRAINS, SELF, sw_articulated_DTX_Glory_20car, extra_callback_info1) {
    1..19: DTX_Glory_20Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

// 유지비 변수
switch(FEAT_TRAINS, SELF, sw_DTX_Glory_running_cost_factor_2025, Use_max_virtual_speed) {
    0;
    }

switch(FEAT_TRAINS, SELF, sw_DTX_Glory_running_cost_factor_2125, Use_max_virtual_speed) {
    150;
    }

switch(FEAT_TRAINS, SELF, sw_DTX_Glory_running_cost_factor, current_year) {
    0..2124: sw_DTX_Glory_running_cost_factor_2025;
    sw_DTX_Glory_running_cost_factor_2125;
    }