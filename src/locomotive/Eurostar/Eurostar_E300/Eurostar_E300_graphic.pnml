/*--------------------------------------------------------------------
구매정보
--------------------------------------------------------------------*/
spriteset(set_Eurostar_E300_1993_purchase, "src/locomotive/Eurostar/Eurostar_E300/Eurostar_E300_1993.png"){
    tmpl_purchase(0, 0)
}

spriteset(set_Eurostar_E300_2015_purchase, "src/locomotive/Eurostar/Eurostar_E300/Eurostar_E300_1993.png"){
    tmpl_purchase(0, 0)
}

// 구매차량 등장년도
switch(FEAT_TRAINS, SELF, sw_Eurostar_E300_purchase, current_year) {
    0..2014: set_Eurostar_E300_1993_purchase;
    set_Eurostar_E300_2015_purchase;
    }