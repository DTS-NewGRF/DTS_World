//도색명
switch(FEAT_TRAINS, SELF, sw_Eurostar_E300_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_Eurostar_E300_1993);
    1: return string(STR_REFIT_LIVERY_Eurostar_E300_2015);
    return CB_RESULT_NO_TEXT;
}

// 도색그래픽 세팅
// 열차
// 전진방향
switch(FEAT_TRAINS, SELF, sw_Eurostar_E300_engineH_Front, cargo_subtype) {
    0: set_Eurostar_E300_1993_engineH;
    1: set_Eurostar_E300_2015_engineH;
}

switch(FEAT_TRAINS, SELF, sw_Eurostar_E300_wagon_M1, cargo_subtype) {
    0: set_Eurostar_E300_1993_wagon_M1;
    1: set_Eurostar_E300_2015_wagon_M1;
}

switch(FEAT_TRAINS, SELF, sw_Eurostar_E300_wagon_T1, cargo_subtype) {
    0: set_Eurostar_E300_1993_wagon_T1;
    1: set_Eurostar_E300_2015_wagon_T1;    
}

switch(FEAT_TRAINS, SELF, sw_Eurostar_E300_wagon_C1, cargo_subtype) {
    0: set_Eurostar_E300_1993_wagon_C1;
    1: set_Eurostar_E300_2015_wagon_C1;
}

switch(FEAT_TRAINS, SELF, sw_Eurostar_E300_wagon_L1, cargo_subtype) {
    0: set_Eurostar_E300_1993_wagon_L1;
    1: set_Eurostar_E300_2015_wagon_L1;
}

