// 도색명
switch(FEAT_TRAINS, SELF, sw_DHC_PP_4Car_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_DHC_New_A);
    1: return string(STR_REFIT_LIVERY_DHC_New_B);
    2: return string(STR_REFIT_LIVERY_DHC_OL_A);
    3: return string(STR_REFIT_LIVERY_DHC_OL_B);
}

