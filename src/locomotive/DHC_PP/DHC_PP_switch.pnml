     1: return string(STR_REFIT_LIVERY_DHC_New_Cafe_B); //신도색 카페객차 B
     2: return string(STR_REFIT_LIVERY_DHC_New_Cafe_C); //신도색 일반실 카페객차
     3: return string(STR_REFIT_LIVERY_DHC_New_A);      //신도색 A
     4: return string(STR_REFIT_LIVERY_DHC_New_B);      //신도색 B
     5: return string(STR_REFIT_LIVERY_DHC_New_C);      //신도색 일반실
     6: return string(STR_REFIT_LIVERY_DHC_OL_A);       //구도색 후기형 A
     7: return string(STR_REFIT_LIVERY_DHC_OL_B);       //구도색 후기형 B
     8: return string(STR_REFIT_LIVERY_DHC_OL_C);       //구도색 후기형 일반실
     9: return string(STR_REFIT_LIVERY_DHC_OLS);        //구도색 후기형 특실도색
    10: return string(STR_REFIT_LIVERY_DHC_FL_A);       //초기도색 후기형 A
    11: return string(STR_REFIT_LIVERY_DHC_FL_B);       //초기도색 후기형 B
    12: return string(STR_REFIT_LIVERY_DHC_FLS);        //초기도색 후기형 특실도색
}

