spriteset(set_Tokaido_Sanyo_engineH, "src/locomotive/Shinkansen/Shinkansen_N700/Tokaido_Sanyo.png"){
    DTS_temp(80, 0)
}

spriteset(set_Tokaido_Sanyo_panto_wagon, "src/locomotive/Shinkansen/Shinkansen_N700/Tokaido_Sanyo.png"){
    DTS_temp(80, 27)
}

