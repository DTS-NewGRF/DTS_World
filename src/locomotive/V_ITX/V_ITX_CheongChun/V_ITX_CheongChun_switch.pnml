/*--------------------------------------------------------------------
스위치
--------------------------------------------------------------------*/
// 도색명
switch(FEAT_TRAINS, SELF, sw_V_ITX_CheongChun_cargo_subtype_text, cargo_subtype) {
    1: return string(STR_REFIT_LIVERY_ITX_CheongChun_B);
    return string(STR_REFIT_LIVERY_ITX_CheongChun_A);
}

// 편성그래픽
// 6량
switch (FEAT_TRAINS, SELF, sw_V_ITX_CheongChun_6car, position_in_vehid_chain % 6) {
    1:set_ITX_CheongChun_panto_wagon_M1;
    2:set_ITX_CheongChun_wagon_M1;
    3:set_ITX_CheongChun_wagon_M2;
    4:set_ITX_CheongChun_panto_wagon_M2;
    5:sw_ITX_CheongChun_engineT;
    sw_ITX_CheongChun_engineH; //default
    }

switch (FEAT_TRAINS, SELF, sw_V_ITX_CheongChun_6car_r, position_in_vehid_chain % 6) {
    1:set_ITX_CheongChun_panto_wagon_M2_r;
    2:set_ITX_CheongChun_wagon_M2_r;
    3:set_ITX_CheongChun_wagon_M1_r;
    4:set_ITX_CheongChun_panto_wagon_M1_r;
    5:sw_ITX_CheongChun_engineH_r;
    sw_ITX_CheongChun_engineT_r; //default
    }

switch(FEAT_TRAINS, SELF, sw_V_ITX_CheongChun_6car_flipped, vehicle_is_flipped){
    0: sw_V_ITX_CheongChun_6car_r;
    sw_V_ITX_CheongChun_6car;
}

switch(FEAT_TRAINS, PARENT, sw_V_ITX_CheongChun_6car_reversed, vehicle_is_reversed){
    0: sw_V_ITX_CheongChun_6car;
    sw_V_ITX_CheongChun_6car_flipped;
}

// 10량
switch (FEAT_TRAINS, SELF, sw_V_ITX_CheongChun_10car, position_in_vehid_chain % 10) {
    1:set_ITX_CheongChun_panto_wagon_M1;
    2:set_ITX_CheongChun_wagon_M1;
    3:set_ITX_CheongChun_wagon_T1;
    4:set_ITX_CheongChun_wagon_T2;
    5:set_ITX_CheongChun_wagon_MC;
    6:set_ITX_CheongChun_wagon_T3;
    7:set_ITX_CheongChun_wagon_M2;
    8:set_ITX_CheongChun_panto_wagon_M2;
    9:sw_ITX_CheongChun_engineT;
    sw_ITX_CheongChun_engineH; //default
    }

switch (FEAT_TRAINS, SELF, sw_V_ITX_CheongChun_10car_r, position_in_vehid_chain % 10) {
    1:set_ITX_CheongChun_panto_wagon_M2_r;
    2:set_ITX_CheongChun_wagon_M2_r;
    3:set_ITX_CheongChun_wagon_T3_r;
    4:set_ITX_CheongChun_wagon_MC_r;
    5:set_ITX_CheongChun_wagon_T2_r;
    6:set_ITX_CheongChun_wagon_T1_r;
    7:set_ITX_CheongChun_wagon_M1_r;
    8:set_ITX_CheongChun_panto_wagon_M1_r;
    9:sw_ITX_CheongChun_engineH_r;
    sw_ITX_CheongChun_engineT_r; //default
    }

switch(FEAT_TRAINS, SELF, sw_V_ITX_CheongChun_10car_flipped, vehicle_is_flipped){
    0: sw_V_ITX_CheongChun_10car_r;
    sw_V_ITX_CheongChun_10car;
}

switch(FEAT_TRAINS, PARENT, sw_V_ITX_CheongChun_10car_reversed, vehicle_is_reversed){
    0: sw_V_ITX_CheongChun_10car;
    sw_V_ITX_CheongChun_10car_flipped;
}

// 편성량
switch (FEAT_TRAINS, SELF, sw_articulated_V_ITX_CheongChun_6car, extra_callback_info1) {
    1..5: V_ITX_CheongChun_6Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_V_ITX_CheongChun_10car, extra_callback_info1) {
    1..9: V_ITX_CheongChun_10Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

// 사운드
switch(FEAT_TRAINS, SELF, sw_V_ITX_CheongChun_sound, extra_callback_info1) {
    SOUND_EVENT_START: sound("sounds/TOSHIBAStart.wav");
    SOUND_EVENT_LOAD_UNLOAD: sound("sounds/osfx_20.wav");
    return CB_RESULT_NO_SOUND;
    }

// 속도변수
switch(FEAT_TRAINS, SELF, sw_V_ITX_CheongChun_speed, Use_max_virtual_speed) {
    1: return Semi_High_SPEED_Train;
    return 180;
    }