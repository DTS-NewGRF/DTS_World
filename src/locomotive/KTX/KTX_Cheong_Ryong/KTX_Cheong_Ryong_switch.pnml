switch(FEAT_TRAINS, SELF, sw_KTX_Cheong_Ryong_engineH_Back, cargo_subtype) {
    0: set_KTX_Eum_engineH_Rev;
    1: set_KTX_Cheong_Ryong_engineH_Rev;
    2: set_KTX_Cheong_Ryong_2nd_engineH_Rev;
    3: set_SRT_320_engineH_Rev;
}

