    3: set_SRT_320_engineT_Rev;    
}

// 전후진 통합 코드
switch(FEAT_TRAINS, SELF, sw_KTX_Cheong_Ryong_engineH, train_is_driving_backwards) {
    0: sw_KTX_Cheong_Ryong_engineH_Front;
    1: sw_KTX_Cheong_Ryong_engineH_Back;
}

switch(FEAT_TRAINS, SELF, sw_KTX_Cheong_Ryong_panto_wagon_M1, train_is_driving_backwards) {
    0: sw_KTX_Cheong_Ryong_panto_wagon_M1_Front;
    1: sw_KTX_Cheong_Ryong_panto_wagon_M1_Back;
}

switch(FEAT_TRAINS, SELF, sw_KTX_Cheong_Ryong_panto_wagon_M4, train_is_driving_backwards) {
    0: sw_KTX_Cheong_Ryong_panto_wagon_M4_Front;
    1: sw_KTX_Cheong_Ryong_panto_wagon_M4_Back;
}

switch(FEAT_TRAINS, SELF, sw_KTX_Cheong_Ryong_engineT, train_is_driving_backwards) {
    0: sw_KTX_Cheong_Ryong_engineT_Front;
    1: sw_KTX_Cheong_Ryong_engineT_Back;
}

// 편성그래픽
// 8량
switch (FEAT_TRAINS, SELF, sw_KTX_Cheong_Ryong_8car, position_in_vehid_chain % 8) {
    0: sw_KTX_Cheong_Ryong_engineH; //default
    1: sw_KTX_Cheong_Ryong_panto_wagon_M1;
    2: sw_KTX_Cheong_Ryong_wagon_M21;
    3: sw_KTX_Cheong_Ryong_wagon_M3;
    4: sw_KTX_Cheong_Ryong_wagon_M22;
    5: sw_KTX_Cheong_Ryong_wagon_M2;
    6: sw_KTX_Cheong_Ryong_panto_wagon_M4;
    7: sw_KTX_Cheong_Ryong_engineT;
    }

// 16량
switch (FEAT_TRAINS, SELF, sw_KTX_Cheong_Ryong_16car, position_in_vehid_chain % 16) {
     0: sw_KTX_Cheong_Ryong_engineH; //default
     1: sw_KTX_Cheong_Ryong_panto_up_wagon_M1;
     2: sw_KTX_Cheong_Ryong_wagon_M21;
     3: sw_KTX_Cheong_Ryong_wagon_M3;
     4: sw_KTX_Cheong_Ryong_wagon_M22;
     5: sw_KTX_Cheong_Ryong_wagon_M2;
     6: sw_KTX_Cheong_Ryong_panto_down_wagon_M4;
     7: sw_KTX_Cheong_Ryong_engineT_TCD_Rev;
     8: sw_KTX_Cheong_Ryong_engineT_TCD;
     9: sw_KTX_Cheong_Ryong_panto_wagon_M1_Front;
    10: sw_KTX_Cheong_Ryong_wagon_M21;
    11: sw_KTX_Cheong_Ryong_wagon_M3;
    12: sw_KTX_Cheong_Ryong_wagon_M22;
    13: sw_KTX_Cheong_Ryong_wagon_M2;
    14: sw_KTX_Cheong_Ryong_panto_up_wagon_M4;
    15: sw_KTX_Cheong_Ryong_engineT;    
    }

// 편성량
switch (FEAT_TRAINS, SELF, sw_articulated_KTX_Cheong_Ryong_8car, extra_callback_info1) {
    1..7: KTX_Cheong_Ryong_8Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch (FEAT_TRAINS, SELF, sw_articulated_KTX_Cheong_Ryong_16car, extra_callback_info1) {
    1..15: KTX_Cheong_Ryong_16Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

// 수송량
switch(FEAT_TRAINS, SELF, sw_KTX_Cheong_Ryong_capacity_in_custom, cargo_subtype) {
    0: return 65;
    2: return 63;
    3: return 63;
}