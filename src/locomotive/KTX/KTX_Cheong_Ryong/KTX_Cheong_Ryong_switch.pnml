switch(FEAT_TRAINS, SELF, sw_KTX_Cheong_Ryong_engineT_Front, cargo_subtype) {
    0: set_KTX_Eum_engineT;
    1: set_KTX_Cheong_Ryong_engineT;
    2: set_KTX_Cheong_Ryong_2nd_engineT;
