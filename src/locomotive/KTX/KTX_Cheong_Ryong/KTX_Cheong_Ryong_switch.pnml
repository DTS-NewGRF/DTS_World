//도색명
switch(FEAT_TRAINS, SELF, sw_KTX_Cheong_Ryong_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_KTX_Cheong_Ryong_Eum);
    1: return string(STR_REFIT_LIVERY_KTX_Cheong_Ryong);
    2: return string(STR_REFIT_LIVERY_KTX_Cheong_Ryong_2nd);
    3: return string(STR_REFIT_LIVERY_SRT_320);
    return CB_RESULT_NO_TEXT;
}

// 도색그래픽 세팅
// 열차
// 전진방향
switch(FEAT_TRAINS, SELF, sw_KTX_Cheong_Ryong_engineH_Front, cargo_subtype) {
    0: set_KTX_Eum_engineH;
    1: set_KTX_Cheong_Ryong_engineH;
    2: set_KTX_Cheong_Ryong_2nd_engineH;
    3: set_SRT_320_engineH;
}

switch(FEAT_TRAINS, SELF, sw_KTX_Cheong_Ryong_panto_wagon_M1_Front, cargo_subtype) {
    0: set_KTX_Eum_panto_down_wagon_M1;
    1: set_KTX_Cheong_Ryong_panto_down_wagon_M1;
    2: set_KTX_Cheong_Ryong_2nd_panto_down_wagon_M1;
    3: set_SRT_320_panto_down_wagon_M1;
}

