//도색명
switch(FEAT_TRAINS, SELF, sw_KTX_Sancheon_20Car_cargo_subtype_text, cargo_subtype) {
     1: return string(STR_REFIT_LIVERY_KTX_Sancheon_A2A1);  // KTX-산천 A2+A1
     2: return string(STR_REFIT_LIVERY_KTX_Sancheon_A1SRT); // KTX-산천 A1+SRT
     3: return string(STR_REFIT_LIVERY_KTX_Sancheon_A2SRT); // KTX-산천 A2+SRT
     4: return string(STR_REFIT_LIVERY_KTX_Sancheon_SRTA1); // SRT+KTX-산천 A1
     5: return string(STR_REFIT_LIVERY_KTX_Sancheon_SRTA2); // SRT+KTX-산천 A2
     6: return string(STR_REFIT_LIVERY_KTX_Sancheon_A1B);   // KTX-산천 A1+B
     7: return string(STR_REFIT_LIVERY_KTX_Sancheon_A1BP);  // KTX-산천 A1+평창도색
     8: return string(STR_REFIT_LIVERY_KTX_Sancheon_A2B);   // KTX-산천 A2+B
     9: return string(STR_REFIT_LIVERY_KTX_Sancheon_A2BP);  // KTX-산천 A2+평창도색
    10: return string(STR_REFIT_LIVERY_KTX_Sancheon_BA1);   // KTX-산천 B타입+A1
    11: return string(STR_REFIT_LIVERY_KTX_Sancheon_BA2);   // KTX-산천 B타입+A2
    12: return string(STR_REFIT_LIVERY_KTX_Sancheon_BPA1);  // KTX-산천 평창도색+A1
    13: return string(STR_REFIT_LIVERY_KTX_Sancheon_BPA2);  // KTX-산천 평창도색+A2
    14: return string(STR_REFIT_LIVERY_KTX_Sancheon_BSRT);  // KTX-산천 B타입+SRT
    15: return string(STR_REFIT_LIVERY_KTX_Sancheon_SRTB);  // SRT+KTX-산천 B타입
    return string(STR_REFIT_LIVERY_KTX_Sancheon_A1A2);      // KTX-산천 A1+A2
}

