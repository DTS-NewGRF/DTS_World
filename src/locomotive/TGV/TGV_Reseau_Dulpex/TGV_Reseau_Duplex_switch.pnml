/*--------------------------------------------------------------------
스위치
--------------------------------------------------------------------*/
// 도색명
switch(FEAT_TRAINS, SELF, sw_TGV_Reseau_Duplex_cargo_subtype_text, cargo_subtype) {
    0: return string(STR_REFIT_LIVERY_TGV_Atlantic);
    1: return string(STR_REFIT_LIVERY_TGV_Carmillon);
}

// 도색그래픽 세팅
// 열차
// 전진방향
switch(FEAT_TRAINS, SELF, sw_TGV_Reseau_Duplex_engineH_Front, cargo_subtype) {
    0: set_TGV_Reseau_Duplex_engineH;
    1: set_TGV_Reseau_Duplex_Carmillon_engineH;
}

switch(FEAT_TRAINS, SELF, sw_TGV_Reseau_Duplex_wagon_F1, cargo_subtype) {
    0: set_TGV_Reseau_Duplex_wagon_F1;
    1: set_TGV_Reseau_Duplex_Carmillon_wagon_F1;
}

switch(FEAT_TRAINS, SELF, sw_TGV_Reseau_Duplex_wagon_F2, cargo_subtype) {
    0: set_TGV_Reseau_Duplex_wagon_F2;
    1: set_TGV_Reseau_Duplex_Carmillon_wagon_F2;
}

switch(FEAT_TRAINS, SELF, sw_TGV_Reseau_Duplex_wagon_C, cargo_subtype) {
    0: set_TGV_Reseau_Duplex_wagon_C;
    1: set_TGV_Reseau_Duplex_Carmillon_wagon_C;
}

switch(FEAT_TRAINS, SELF, sw_TGV_Reseau_Duplex_wagon_T1, cargo_subtype) {
    0: set_TGV_Reseau_Duplex_wagon_T1;
    1: set_TGV_Reseau_Duplex_Carmillon_wagon_T1;
}

switch(FEAT_TRAINS, SELF, sw_TGV_Reseau_Duplex_wagon_T2, cargo_subtype) {
    0: set_TGV_Reseau_Duplex_wagon_T2;
    1: set_TGV_Reseau_Duplex_Carmillon_wagon_T2;
}

switch(FEAT_TRAINS, SELF, sw_TGV_Reseau_Duplex_engineT_Front, cargo_subtype) {
    0: set_TGV_Reseau_Duplex_engineT;
    1: set_TGV_Reseau_Duplex_Carmillon_engineT;
}

// 후진방향
switch(FEAT_TRAINS, SELF, sw_TGV_Reseau_Duplex_engineH_Back, cargo_subtype) {
    0: set_TGV_Reseau_Duplex_engineH_Rev;
    1: set_TGV_Reseau_Duplex_Carmillon_engineH_Rev;
}

switch(FEAT_TRAINS, SELF, sw_TGV_Reseau_Duplex_engineT_Back, cargo_subtype) {
    0: set_TGV_Reseau_Duplex_engineT_Rev;
    1: set_TGV_Reseau_Duplex_Carmillon_engineT_Rev;
}

// 전후진 통합 코드
switch(FEAT_TRAINS, SELF, sw_TGV_Reseau_Duplex_engineH, train_is_driving_backwards) {
    0: sw_TGV_Reseau_Duplex_engineH_Front;
    1: sw_TGV_Reseau_Duplex_engineH_Back;
}

switch(FEAT_TRAINS, SELF, sw_TGV_Reseau_Duplex_engineT, train_is_driving_backwards) {
    0: sw_TGV_Reseau_Duplex_engineT_Front;
    1: sw_TGV_Reseau_Duplex_engineT_Back;
}

// 편성그래픽
switch (FEAT_TRAINS, SELF, sw_TGV_Reseau_Duplex_10car, position_in_vehid_chain % 10) {
    0: sw_TGV_Reseau_Duplex_engineH; //default
    1: sw_TGV_Reseau_Duplex_wagon_F1;
    2..3: sw_TGV_Reseau_Duplex_wagon_F2;
    4: sw_TGV_Reseau_Duplex_wagon_C;
    5..7: sw_TGV_Reseau_Duplex_wagon_T1;
    8: sw_TGV_Reseau_Duplex_wagon_T2;
    9: sw_TGV_Reseau_Duplex_engineT;
    }

// 편성수
switch (FEAT_TRAINS, SELF, sw_articulated_TGV_Reseau_Duplex_10car, extra_callback_info1) {
    1..9: TGV_Reseau_Duplex_10Car;
    return CB_RESULT_NO_MORE_ARTICULATED_PARTS;
    }

switch(FEAT_TRAINS, SELF, sw_TGV_Reseau_Duplex_wagon_length_in_custom, position_in_vehid_chain % 10) {
    0..1: 8; //default;
    2..7: 7;
    8..9: 8;
    9: 8;
}