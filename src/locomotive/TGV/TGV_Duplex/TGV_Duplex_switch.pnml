    5: set_TGV_Duplex_Ouigo_wagon_F2;
    set_TGV_Duplex_wagon_F2;
}

switch(FEAT_TRAINS, SELF, sw_TGV_Duplex_wagon_C, cargo_subtype) {
    1: set_TGV_Duplex_wagon_C;
    2: set_TGV_Duplex_Carmillon_wagon_C;
    3: set_TGV_Duplex_Carmillon_wagon_C;
    4: set_TGV_Duplex_Lyair_wagon_C;
    5: set_TGV_Duplex_Ouigo_wagon_C;
    set_TGV_Duplex_wagon_C;
}

switch(FEAT_TRAINS, SELF, sw_TGV_Duplex_wagon_T1, cargo_subtype) {
    1: set_TGV_Duplex_wagon_T1;
    2: set_TGV_Duplex_Carmillon_wagon_T1;
    3: set_TGV_Duplex_Carmillon_wagon_T1;
    4: set_TGV_Duplex_Lyair_wagon_T1;
    5: set_TGV_Duplex_Ouigo_wagon_T1;
    set_TGV_Duplex_wagon_T1;
}

switch(FEAT_TRAINS, SELF, sw_TGV_Duplex_wagon_T2, cargo_subtype) {
    1: set_TGV_Duplex_wagon_T2;
    2: set_TGV_Duplex_Carmillon_wagon_T2;
    3: set_TGV_Duplex_Carmillon_wagon_T2;
    4: set_TGV_Duplex_Lyair_wagon_T2;
