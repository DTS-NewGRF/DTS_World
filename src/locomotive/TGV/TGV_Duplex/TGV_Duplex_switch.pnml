/*--------------------------------------------------------------------
스위치
--------------------------------------------------------------------*/
// 도색명
switch(FEAT_TRAINS, SELF, sw_TGV_Duplex_cargo_subtype_text, cargo_subtype) {
    1: return string(STR_REFIT_LIVERY_TGV_Atlantic_2nd);
    2: return string(STR_REFIT_LIVERY_TGV_Carmillon_1st);
    3: return string(STR_REFIT_LIVERY_TGV_Carmillon_2nd);
    4: return string(STR_REFIT_LIVERY_TGV_Lyair);
    5: return string(STR_REFIT_LIVERY_TGV_Ouigo);
    return string(STR_REFIT_LIVERY_TGV_Atlantic_1st);
}

// 10량
switch(FEAT_TRAINS, SELF, sw_TGV_Duplex_engineH, cargo_subtype) {
    1: set_TGV_Duplex_engineH;
    2: set_TGV_Duplex_Carmillon_engineH;
    3: set_TGV_Duplex_Carmillon_engineH;
    4: set_TGV_Duplex_Lyair_engineH;
    5: set_TGV_Duplex_Ouigo_engineH;
    set_TGV_Duplex_engineH;
}

switch(FEAT_TRAINS, SELF, sw_TGV_Duplex_wagon_F1, cargo_subtype) {
    1: set_TGV_Duplex_wagon_F1;
    2: set_TGV_Duplex_Carmillon_wagon_F1;
    3: set_TGV_Duplex_Carmillon_wagon_F1;
    4: set_TGV_Duplex_Lyair_wagon_F1;
    5: set_TGV_Duplex_Ouigo_wagon_F1;
    set_TGV_Duplex_wagon_F1;
}

